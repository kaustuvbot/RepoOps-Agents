{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "cat AGENTS.md 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".codex/scripts/session-update.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
